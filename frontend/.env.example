# Frontend environment. Copy to `.env` and fill in.

# Where the SvelteKit app proxies /api/* in development.
# Production deployments rewrite /api/* via reverse proxy and ignore this.
API_PROXY_TARGET=http://127.0.0.1:8080

# Absolute API base used during server-side rendering. REQUIRED in production:
# SSR must call the API directly (e.g. http://api:8080), never a relative /api,
# which would loop back through this server and recurse to OOM. In local dev
# leave it unset — the app falls back to API_PROXY_TARGET (see
# src/lib/api/client.ts). NOTE: read from the real process environment, NOT
# from this .env file.
# INTERNAL_API_BASE_URL=http://127.0.0.1:8080

# Sandbox demo banner. When "true", every page shows a top banner stating the
# data is seeded and nothing is binding — use it on demo/sandbox deployments so
# visitors never mistake seeded figures for real civic activity. Leave unset or
# "false" in real production. Read at runtime via $env/dynamic/public.
PUBLIC_DEMO_MODE=false
