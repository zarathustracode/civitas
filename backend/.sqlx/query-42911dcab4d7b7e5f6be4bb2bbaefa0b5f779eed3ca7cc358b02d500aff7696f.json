  "query": "\n        select distinct on (voter_id)\n            id          as \"id: VoteId\",\n            proposal_id as \"proposal_id: ProposalId\",\n            voter_id    as \"voter_id: UserId\",\n            choice      as \"choice: VoteChoice\",\n            cast_at\n        from votes\n        where proposal_id = $1\n        order by voter_id, cast_at desc\n        ",
