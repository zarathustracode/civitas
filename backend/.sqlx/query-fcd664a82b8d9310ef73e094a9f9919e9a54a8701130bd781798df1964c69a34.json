  "query": "\n        select\n            id           as \"id: AuditLogId\",\n            actor_id     as \"actor_id: UserId\",\n            action,\n            entity_type,\n            entity_id,\n            metadata     as \"metadata!: JsonValue\",\n            created_at\n        from audit_log\n        where entity_type = $1 and entity_id = $2\n        order by created_at desc\n        limit $3\n        ",
