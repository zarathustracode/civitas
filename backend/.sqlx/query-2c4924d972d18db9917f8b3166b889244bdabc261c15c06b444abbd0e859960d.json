{
  "db_name": "PostgreSQL",
  "query": "\n        select\n            id, user_id as \"user_id: UserId\",\n            created_at, last_seen_at, expires_at, revoked_at,\n            user_agent, ip_address\n        from sessions\n        where token_hash = $1\n          and revoked_at is null\n          and expires_at > now()\n        ",
