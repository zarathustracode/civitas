  "query": "\n        select\n            id as \"id: ProposalId\",\n            topic_id as \"topic_id: TopicId\",\n            title, summary, body,\n            author_id as \"author_id: UserId\",\n            status as \"status: ProposalStatus\",\n            voting_starts_at, voting_ends_at,\n            created_at, updated_at\n        from proposals\n        where status = $1\n        order by created_at desc\n        ",
