# Civitas environment configuration — copy to `.env` and fill in.
# Never commit a real `.env`. Secrets must be rotated if leaked.

# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://civitas:civitas@localhost:5432/civitas
DATABASE_MAX_CONNECTIONS=20

# ─── HTTP server ─────────────────────────────────────────────────────────────
HTTP_LISTEN_ADDR=127.0.0.1:8080
PUBLIC_BASE_URL=http://localhost:5173

# ─── Sessions / cookies ──────────────────────────────────────────────────────
# 32+ random bytes, base64-encoded. Generate with:
#   openssl rand -base64 48
COOKIE_SECRET=replace-me-with-32-or-more-random-bytes
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false   # set true in production (HTTPS only)

# ─── Argon2id (password hashing) ─────────────────────────────────────────────
# Defaults are tuned for 2025+ hardware. Override only with profiling data.
ARGON2_MEMORY_KIB=19456
ARGON2_ITERATIONS=2
ARGON2_PARALLELISM=1

# ─── Email (verification, recovery) ──────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Civitas <noreply@localhost>"

# ─── Logging ─────────────────────────────────────────────────────────────────
# tracing-subscriber EnvFilter syntax. Keep PII out of logs.
RUST_LOG=civitas=info,tower_http=info,sqlx=warn

# ─── Background jobs ─────────────────────────────────────────────────────────
# Interval at which the API process scans for voting proposals whose
# voting_ends_at has elapsed and transitions them to `closed`. Production
# default is 60s; dev/E2E may want a tight loop (clamped to >= 1).
AUTO_CLOSE_INTERVAL_SECS=60

# ─── Dev-only conveniences (NEVER set in production) ─────────────────────────
# When true, POST /auth/register echoes the verification token in its
# response body so the frontend can pre-fill the verify-email page. This
# short-circuits the email-verification ceremony — only enable for local
# development and CI.
DEV_RETURN_VERIFICATION_TOKEN=false

# ─── Frontend (SvelteKit) ────────────────────────────────────────────────────
PUBLIC_API_BASE_URL=http://localhost:8080
